model Monsters {
	number Int @id

	name       String?
	image_url  String?
	source_url String?

	element       String?
	type          String?
	evolution     String?
	obtain_method String?
	star          Int?
	category      String?

	info      String[]
	passive   String[]
	abilities String[]
	ss        String?

	createdAt DateTime @default(now())
}
